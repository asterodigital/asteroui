{
  "name": "asteroui",
  "description": "Astero UI : Complete Bootstrap-based front and backend template system.",
  "version": "1.0.3",
  "license": "MIT",
  "author": "AsteroDigital <https://asterodigital.com>",
  "packageManager": "pnpm@10.30.2",
  "scripts": {
    "dev": "node tools/dev.mjs",
    "build": "node tools/build.mjs",
    "build:offline": "pnpm run css && pnpm run js && node tools/build-offline.mjs",
    "build:all": "pnpm run build && pnpm run build:offline",
    "css": "node tools/css.mjs",
    "js": "node tools/js.mjs",
    "assets": "node tools/assets.mjs",
    "lint": "node tools/lint.mjs",
    "fixlint": "node tools/fixlint.mjs",
    "format:html": "node tools/format.mjs",
    "format": "prettier --write \"**/*.{js,ts,jsx,tsx,json,md,mdx,css,scss,html,astro,mjs}\"",
    "clean": "node tools/clean.mjs",
    "clean:offline": "node tools/clean.mjs",
    "watch": "node tools/watch.mjs",
    "serve": "node tools/serve.mjs",
    "serve:offline": "node tools/serve-offline.mjs",
    "bundlewatch": "bundlewatch --config .bundlewatch.config.json",
    "smoke": "node tools/smoke.mjs",
    "lint:md": "markdownlint \"**/*.{md,mdx}\" --config .markdownlintrc.json",
    "format:md": "markdownlint --fix \"**/*.{md,mdx}\" --config .markdownlintrc.json"
  },
  "keywords": [
    "asteroui",
    "premium",
    "homeowner association",
    "community",
    "website",
    "astro",
    "css",
    "sass",
    "responsive",
    "admin",
    "template",
    "theme",
    "framework",
    "bootstrap",
    "hoa"
  ],
  "homepage": "https://asteroui.asterodigital.com/",
  "style": "dist/styles/asteroui.css",
  "sass": "src/styles/asteroui.scss",
  "devDependencies": {
    "@stylistic/stylelint-plugin": "^5.1.0",
    "@astrojs/check": "^0.9.8",
    "@astrojs/mdx": "^5.0.3",
    "@astrojs/prism": "^4.0.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@rollup/plugin-commonjs": "^29.0.2",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "@types/rtlcss": "^3.5.4",
    "@typescript-eslint/eslint-plugin": "^8.58.1",
    "@typescript-eslint/parser": "^8.58.1",
    "astro": "^6.1.5",
    "astro-eslint-parser": "^1.4.0",
    "autoprefixer": "^10.4.27",
    "bundlewatch": "^0.4.1",
    "chalk": "^5.6.2",
    "chokidar": "^5.0.0",
    "clean-css-cli": "^5.6.3",
    "concurrently": "^9.2.1",
    "cross-env": "^10.1.0",
    "cross-spawn": "^7.0.6",
    "cssnano": "^7.1.4",
    "cssnano-preset-advanced": "^7.0.12",
    "esbuild": "^0.28.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-xo": "^0.51.0",
    "eslint-plugin-astro": "^1.7.0",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-unicorn": "^64.0.0",
    "express": "^5.2.1",
    "fs-extra": "^11.3.4",
    "glob": "^13.0.6",
    "markdownlint": "^0.40.0",
    "markdownlint-cli": "^0.48.0",
    "npm-run-all": "^4.1.5",
    "open": "^11.0.0",
    "postcss": "^8.5.9",
    "postcss-cli": "^11.0.1",
    "prettier": "^3.8.1",
    "prettier-plugin-astro": "^0.14.1",
    "rollup": "^4.60.1",
    "rtlcss": "^4.3.0",
    "sass-embedded": "^1.99.0",
    "stylelint": "^17.6.0",
    "stylelint-config-recommended": "^18.0.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-config-twbs-bootstrap": "^16.1.0",
    "typescript": "^6.0.2",
    "unist-util-visit": "^5.1.0",
    "xo": "^2.0.2"
  },
  "dependencies": {
    "bootstrap": "^5.3.8"
  }
}